{
    "name": "kachuru/zone",
    "type": "symfony-bundle",
    "license": "proprietary",
    "description": "Zone",
    "require": {
        "php": "^8.3|^8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "kachuru/map-maker": "^1.0",
        "kachuru/util": "^2.1",
        "symfony/config": "^7.3",
        "symfony/dependency-injection": "^7.3",
        "symfony/framework-bundle": "^7.3",
        "symfony/http-foundation": "^7.3",
        "symfony/http-kernel": "^7.3",
        "symfony/routing": "^7.3",
        "twig/twig": "^3.21"
    },
    "require-dev": {
        "friends-of-phpspec/phpspec-code-coverage": "^7.0",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpspec/phpspec": "^8.2",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^3.13"
    },
    "config": {
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "Kachuru\\Zone\\": "src/Kachuru/Zone/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "spec\\Kachuru\\Zone\\": "spec/Kachuru/Zone/"
        }
    },
    "scripts": {
        "spec": [
            "vendor/bin/phpspec run"
        ],
        "coverage": [
            "phpdbg -qrr vendor/bin/phpspec -c phpspec-phpdbg.yml run"
        ],
        "sniff": [
            "vendor/bin/phpcs --standard=PSR2 --extensions=php src/"
        ],
        "fix": [
            "vendor/bin/phpcbf --standard=PSR2 --extensions=php src/"
        ],
        "stan": [
            "vendor/bin/phpstan analyse src/ --level max"
        ],
        "compatibility": [
            "vendor/bin/phpcs -s --standard=vendor/phpcompatibility/php-compatibility/PHPCompatibility/ --runtime-set testVersion 8.3- src/",
            "vendor/bin/phpcs -s --standard=vendor/phpcompatibility/php-compatibility/PHPCompatibility/ --runtime-set testVersion 8.4- src/"
        ],
        "test": [
            "@sniff",
            "@spec",
            "@stan",
            "@compatibility"
        ]
    }
}
